    },
    {
      "page": "/fees",
      "regex": "^/fees(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/fees(?:/)?$"
    },
    {
      "page": "/gallery",
      "regex": "^/gallery(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/gallery(?:/)?$"
    },
    {
      "page": "/learning-levels",
      "regex": "^/learning\\-levels(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/learning\\-levels(?:/)?$"
    },
    {
      "page": "/lessons",
      "regex": "^/lessons(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/lessons(?:/)?$"
    },
    {
      "page": "/online",
      "regex": "^/online(?:/)?$",
